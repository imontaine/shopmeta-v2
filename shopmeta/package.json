{
  "name": "shopmeta",
  "version": "0.3.8",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000 --strictPort",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts --reporter=verbose",
    "test:component": "vitest run --config vitest.component.config.ts --reporter=verbose",
    "test:integration": "vitest run --reporter=verbose --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live": "playwright test --project=chromium",
    "test:e2e:prod": "cross-env E2E_BASE_URL=https://app.shopmeta.app E2E_SKIP_WEBSERVER=true E2E_SKIP_MIGRATIONS=true playwright test",
    "test:e2e:prod:headed": "cross-env E2E_BASE_URL=https://app.shopmeta.app E2E_SKIP_WEBSERVER=true E2E_SKIP_MIGRATIONS=true playwright test --headed",
    "test:all": "pnpm test:unit && pnpm test:component && pnpm test:e2e",
    "test:all:prod": "pnpm test:unit && pnpm test:component && pnpm test:smoke && pnpm test:e2e:prod",
    "test:smoke": "vitest run --reporter=verbose --config vitest.integration.config.ts tests/integration/chat/smoke-real-api.test.ts",
    "playwright:install": "playwright install chromium",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:e2e": "dotenv -e .env.e2e -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed-skills": "tsx src/lib/skills-sync.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.10.4",
    "@better-fetch/fetch": "^1.3.1",
    "@clickhouse/client": "^1.11.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/ai": "^0.35.0",
    "@tanstack/ai-anthropic": "^0.15.8",
    "@tanstack/ai-mcp": "^0.1.8",
    "@tanstack/ai-openai": "^0.15.6",
    "@tanstack/ai-react": "^0.15.13",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.12.3",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.9",
    "@tanstack/router-plugin": "^1.132.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "better-auth": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "fflate": "^0.8.3",
    "lucide-react": "^0.545.0",
    "marked": "^18.0.5",
    "msw": "^2.14.6",
    "postgres": "^3.4.7",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^1.5.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^2.15.3",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@better-auth/memory-adapter": "^1.6.20",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testcontainers/postgresql": "^10.24.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.11.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.1",
    "jsdom": "^28.1.0",
    "testcontainers": "^10.24.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
