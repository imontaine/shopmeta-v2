{
  "name": "shopmeta-v2",
  "version": "0.1.5",
  "private": true,
  "description": "LibreChat whitelabel deployment for shopmeta.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/imontaine/shopmeta-v2.git"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "version:patch": "npm version patch -m \"release: v%s\"",
    "version:minor": "npm version minor -m \"release: v%s\"",
    "version:major": "npm version major -m \"release: v%s\"",
    "deploy": "npm version patch -m \"deploy: v%s\" && git push --no-verify && git push --tags --no-verify"
  }
}
